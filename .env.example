# Algorand network (defaults to AlgoNode TestNet — no API key required).
# MainNet:  ALGO_SERVER=https://mainnet-api.algonode.cloud
#           INDEX_SERVER=https://mainnet-idx.algonode.cloud
ALGO_SERVER=https://testnet-api.algonode.cloud
INDEX_SERVER=https://testnet-idx.algonode.cloud
ALGO_PORT=

# Account that pays the 0-Algo "note" transactions used as the IPFS index.
ADDRESS=
# Comma-separated bytes of the 64-byte secret key (Uint8Array).
SK=

# Optional symmetric password for client-side AES-256-CBC encryption.
ENCRYPTION_PASSWORD=

# IPFS endpoints. Defaults: local Kubo daemon for writes, ipfs.io for reads.
# Point IPFS_API_URL at any kubo-compatible HTTP RPC (Pinata, web3.storage, ...).
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=https://ipfs.io
